# このファイルをコピーして .env を作成してください
#   cp .env.example .env
#
# .env は git 管理外 (.gitignore 済み)。本番では別の値に差し替える。

# ==== PostgreSQL ====
POSTGRES_USER=cardgame
POSTGRES_PASSWORD=cardgame_pass
POSTGRES_DB=cardgame_db

# ==== Backend → DB 接続 ====
# host=db はコンテナ内ネットワークでの参照名 (docker-compose のサービス名)
DB_HOST=db
DB_PORT=5432
DB_USER=cardgame
DB_PASSWORD=cardgame_pass
DB_NAME=cardgame_db

# ==== Backend ====
PORT=3001

# ==== pgAdmin ====
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
